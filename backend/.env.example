# ===========================================
# Course Teaching Agent — 环境变量模板
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# API Key 优先级：
#   1. 系统环境变量 ali-qwen3-max-api（推荐生产使用）
#   2. 下方 DASHSCOPE_API_KEY（开发环境备用）
DASHSCOPE_API_KEY=your-dashscope-api-key-here

# 大模型配置
LLM_MODEL=qwen3-max
EMBEDDING_MODEL=text-embedding-v3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# 数据库（SQLite 路径）
DATABASE_URL=sqlite:///./course_teaching_agent.db

# JWT 密钥（生产环境请更换为强随机字符串）
SECRET_KEY=change-this-to-a-strong-random-key

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=course_document_chunks

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# 调试模式
DEBUG=true
